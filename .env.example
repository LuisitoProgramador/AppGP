# --- Cliente (navegador) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# --- Notificaciones de Telegram (solo servidor / Vercel) ---
# El cron diario (api/cron.ts) envía avisos de presupuesto, corte, pago y resumen.
# NO llevan prefijo VITE_ y nunca deben exponerse al navegador.
#
# 1. Crea un bot con @BotFather → TELEGRAM_BOT_TOKEN
# 2. Obtén tu chat id con @userinfobot → TELEGRAM_CHAT_ID
# 3. En Vercel: Project Settings → Environment Variables (Production)
TELEGRAM_BOT_TOKEN=123456:tu-bot-token
TELEGRAM_CHAT_ID=tu-chat-id

# Service role de Supabase: permite al cron leer datos sin sesión (omite RLS).
# Supabase → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
# Opcional: si SUPABASE_URL no está, el cron usa VITE_SUPABASE_URL.
SUPABASE_URL=https://tu-proyecto.supabase.co

# Secreto que protege /api/cron. Vercel Cron lo envía como
# "Authorization: Bearer <CRON_SECRET>". Genera uno aleatorio largo.
CRON_SECRET=un-secreto-largo-y-aleatorio

# Opcional (app personal): limita las notificaciones a un solo usuario.
# UUID de auth.users en Supabase. Si se omite, el cron procesa a todos.
NOTIFY_USER_ID=
