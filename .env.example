# --- Cliente (navegador) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# --- Notificaciones de Telegram (solo servidor / Vercel) ---
# El cron diario (api/cron.ts) usa estas variables. NO llevan prefijo VITE_
# y nunca deben exponerse al navegador.
TELEGRAM_BOT_TOKEN=123456:tu-bot-token
TELEGRAM_CHAT_ID=tu-chat-id

# Service role de Supabase: permite al cron leer datos sin sesión (omite RLS).
# Cópiala de Supabase > Project Settings > API. Mantenla en secreto.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
# Opcional: si SUPABASE_URL no está, el cron usa VITE_SUPABASE_URL.
SUPABASE_URL=https://tu-proyecto.supabase.co

# Secreto que protege /api/cron. Vercel Cron lo envía como
# "Authorization: Bearer <CRON_SECRET>". Si se define, el endpoint lo exige.
CRON_SECRET=un-secreto-largo-y-aleatorio

# Opcional (app personal): limita las notificaciones a un solo usuario.
# Si se omite, el cron procesa a todos los usuarios con datos.
NOTIFY_USER_ID=
